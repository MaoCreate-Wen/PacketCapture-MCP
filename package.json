{
  "name": "packetcapture-mcp",
  "version": "0.1.0",
  "description": "MCP server for automated packet capture and Reqable export analysis",
  "type": "module",
  "bin": {
    "packetcapture-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "mcp",
    "packet-capture",
    "har",
    "reqable",
    "http-analysis"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
